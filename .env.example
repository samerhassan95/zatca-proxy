APP_NAME="ZATCA Proxy Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zatcaproxy
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

ZATCA_ENVIRONMENT=simulation
API_RATE_LIMIT=1000
API_SECRET_KEY=your-super-secret-api-key-here
ALLOWED_CLIENT_IPS=
REQUIRE_API_KEY=true